# tools/stress/versions.env -- pinned load-tool versions for the heavybag stress campaign.
#
# The orchestrator (modules/ngx_http_heavybag/tests/run-stress-tests.sh) sources this,
# compares the pins against the live `--version` output, and on mismatch it WARNS and
# records BOTH the expected and the found string in summary.json. It NEVER fails on
# version drift -- reproducibility here is DOCUMENTED, not enforced (the absolute req/s
# is machine-specific anyway; the reproducible metric is the enforce-vs-off RATIO).
#
# HTTP/3 is a *capability*, not a version: h2load must be built against ngtcp2 + nghttp3.
# The harness probes `h2load --help` for the HTTP/3 / --alpn-list flag (NOT the version
# string) and SKIPs the H3 dimension when it is absent -- most distro h2load builds ship
# H1/H2 only. HB_STRESS_H2LOAD_H3_EXPECTED only tunes the WARN wording, it is not a gate.

# h2load identifies itself as the nghttp2 it was built from, e.g. "nghttp2/1.61.0".
HB_STRESS_H2LOAD_VERSION="nghttp2/1.61.0"

# wrk2 reports itself as plain "wrk" (it is a wrk fork); the binary may be named
# `wrk2` or `wrk`. The harness accepts either name and matches the leading token.
HB_STRESS_WRK2_VERSION="wrk 4.0.0"

# 1 = this host's h2load is EXPECTED to be QUIC/HTTP-3 capable; 0 = expect H1/H2 only.
HB_STRESS_H2LOAD_H3_EXPECTED=0
